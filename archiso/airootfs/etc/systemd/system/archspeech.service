[Unit]
Description=ArchSpeech AI Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=archspeech
Group=archspeech
ExecStart=/usr/local/bin/archspeech-daemon
Restart=on-failure
RestartSec=5
RuntimeDirectory=archspeech
RuntimeDirectoryMode=0755
LogsDirectory=archspeech
StandardOutput=journal
StandardError=journal
SyslogIdentifier=archspeech

[Install]
WantedBy=multi-user.target
