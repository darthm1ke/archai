[Unit]
Description=ArchSpeech First-Boot Setup Wizard
After=network-online.target
Wants=network-online.target
ConditionPathExists=!/etc/archspeech/.setup_complete

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/archspeech-setup
StandardInput=tty
StandardOutput=tty
StandardError=tty
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes

[Install]
WantedBy=multi-user.target
