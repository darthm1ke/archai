#!/opt/archspeech/bin/python3
"""
ArchAI Guided Installer
AI is active from first screen — greets user, monitors installation,
catches errors and fixes them live on screen.
"""

import os, sys, json, subprocess, asyncio, time, threading
from pathlib import Path

SOCKET_PATH  = "/run/archspeech/daemon.sock"
CONFIG_PATH  = Path("/etc/archspeech/config.json")
PROFILES_DIR = Path("/usr/local/lib/archspeech/installer/profiles")
LOG_PATH     = Path("/var/log/archspeech/execution.log")
VOICE_FIFO   = Path("/run/archspeech/voice_input")

BANNER = """
\033[1;36m █████╗ ██████╗  ██████╗██╗  ██╗     █████╗ ██╗\033[0m
\033[1;36m██╔══██╗██╔══██╗██╔════╝██║  ██║    ██╔══██╗██║\033[0m
\033[1;36m███████║██████╔╝██║     ███████║    ███████║██║\033[0m
\033[1;36m██╔══██║██╔══██╗██║     ██╔══██║    ██╔══██║██║\033[0m
\033[1;36m██║  ██║██║  ██║╚██████╗██║  ██║    ██║  ██║██║\033[0m
\033[1;36m╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝    ╚═╝  ╚═╝╚═╝\033[0m
\033[0;90m ─────────────────────────────────────────────────────────────\033[0m
\033[0;37m  AIos - AI-native Linux, powered by Arch\033[0m
\033[0;90m ─────────────────────────────────────────────────────────────\033[0m
\033[0;37m  Hold \033[1;36mCaps Lock\033[0;37m to speak  │  \033[1;36mRight Ctrl\033[0;37m in a VM  │  Type + \033[1;36mEnter\033[0;37m to write\033[0m
\033[0;90m ─────────────────────────────────────────────────────────────\033[0m
"""

PROFILES = {
    "1": {"key": "gaming",    "label": "Gaming rig",       "pitch": "Ditch Windows for good — Steam, Proton, GameMode, full KDE desktop", "script": PROFILES_DIR / "gaming.sh"},
    "2": {"key": "server",    "label": "Home server",      "pitch": "Own your data — nginx, Docker, SSL, hardened SSH, no desktop bloat",  "script": PROFILES_DIR / "server.sh"},
    "3": {"key": "hobby",     "label": "Hobby machine",    "pitch": "A bit of everything — GNOME, media, dev tools, no commitment",        "script": PROFILES_DIR / "hobby.sh"},
    "4": {"key": "pentest",   "label": "Pentesting lab",   "pitch": "Built like a pro red-teamer — nmap, Metasploit, Wireshark, Tor, XFCE","script": PROFILES_DIR / "pentest.sh"},
    "5": {"key": "developer", "label": "Dev workstation",  "pitch": "Ship things — KDE, VS Code, Docker, full language stack, databases",  "script": PROFILES_DIR / "developer.sh"},
}


# ── Helpers ───────────────────────────────────────────────────────────────────

def clear(): os.system("clear")

def speak(text: str):
    subprocess.Popen(["espeak-ng", "-s", "160", "-p", "50", text],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def ai_print(text: str):
    """Print AI response in cyan with AI prefix."""
    print(f"\n\033[1;36m  AI:\033[0;37m {text}\033[0m\n")

def log(msg: str):
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(LOG_PATH, "a") as f:
        f.write(f"  {msg}\n")


# ── AI connector ──────────────────────────────────────────────────────────────

async def ask_ai(message: str) -> str:
    try:
        reader, writer = await asyncio.open_unix_connection(SOCKET_PATH)
        writer.write(message.encode())
        writer.write_eof()
        await writer.drain()
        response = await reader.read(65536)
        writer.close()
        return response.decode().strip()
    except Exception as e:
        return f"[AI offline: {e}]"

def ai_say(message: str) -> str:
    """Synchronous AI call — blocks until response."""
    try:
        loop = asyncio.new_event_loop()
        response = loop.run_until_complete(ask_ai(message))
        loop.close()
        return response
    except Exception:
        return ""


# ── Voice input pipe ──────────────────────────────────────────────────────────

_voice_queue: list[str] = []

def _voice_reader():
    """Background thread — reads voice transcripts from PTT daemon FIFO."""
    try:
        if not VOICE_FIFO.exists():
            os.mkfifo(str(VOICE_FIFO))
        while True:
            with open(VOICE_FIFO, "r") as f:
                line = f.read().strip()
                if line:
                    _voice_queue.append(line)
    except Exception:
        pass

def get_input(prompt: str) -> str:
    """Read from keyboard OR voice pipe — whichever comes first."""
    print(f"\033[0;36m  {prompt}\033[0m ", end="", flush=True)
    # Start voice reader thread if not running
    if not any(t.name == "voice" for t in threading.enumerate()):
        t = threading.Thread(target=_voice_reader, name="voice", daemon=True)
        t.start()

    while True:
        # Check voice queue first
        if _voice_queue:
            transcript = _voice_queue.pop(0)
            print(f"\033[0;35m[voice: {transcript}]\033[0m")
            return transcript
        # Check if stdin has data (non-blocking)
        import select
        if select.select([sys.stdin], [], [], 0.1)[0]:
            return sys.stdin.readline().strip()


# ── Hardware detection ────────────────────────────────────────────────────────

def detect_disks() -> list[dict]:
    result = subprocess.run(["lsblk", "-J", "-o", "NAME,SIZE,TYPE,MOUNTPOINT"],
                            capture_output=True, text=True)
    disks = []
    try:
        for dev in json.loads(result.stdout).get("blockdevices", []):
            if dev.get("type") == "disk":
                disks.append({"name": f"/dev/{dev['name']}", "size": dev.get("size","?")})
    except Exception:
        pass
    return disks

def detect_gpu() -> str:
    out = subprocess.run(["lspci"], capture_output=True, text=True).stdout.lower()
    if "nvidia" in out: return "NVIDIA"
    if "amd" in out or "radeon" in out: return "AMD"
    if "intel" in out and "vga" in out: return "Intel"
    return "Unknown"

def detect_ram_gb() -> int:
    try:
        with open("/proc/meminfo") as f:
            for line in f:
                if line.startswith("MemTotal"):
                    return int(line.split()[1]) // 1024 // 1024
    except Exception:
        pass
    return 0


# ── Profile selection ─────────────────────────────────────────────────────────

def choose_profile() -> dict:
    print("\n\033[1;37m  What are you building? Pick the closest match:\033[0m\n")
    for num, p in PROFILES.items():
        print(f"  \033[1;36m{num})\033[0m \033[1;37m{p['label']:<22}\033[0m \033[0;90m— {p['pitch']}\033[0m")
    print()

    while True:
        choice = get_input("Enter number or describe what you want:")
        if choice in PROFILES:
            return PROFILES[choice]
        cl = choice.lower()
        if any(w in cl for w in ["game","gaming","steam","windows","play"]): return PROFILES["1"]
        if any(w in cl for w in ["server","host","nginx","docker","headless"]):  return PROFILES["2"]
        if any(w in cl for w in ["hobby","everything","general","casual"]):      return PROFILES["3"]
        if any(w in cl for w in ["pentest","security","hack","nmap","kali"]):     return PROFILES["4"]
        if any(w in cl for w in ["dev","code","develop","vscode","program"]):     return PROFILES["5"]
        print(f"  \033[0;33m  Try entering a number (1-5), or describe it differently.\033[0m\n")


# ── Disk selection ────────────────────────────────────────────────────────────

def choose_disk() -> str:
    disks = detect_disks()
    if not disks:
        ai_print("I can't find any disks. This might be a hardware compatibility issue.")
        sys.exit(1)

    print("\n\033[1;37m  Available disks:\033[0m\n")
    for i, d in enumerate(disks, 1):
        print(f"  \033[1;36m{i})\033[0m {d['name']:<14} \033[0;90m{d['size']}\033[0m")
    print()

    while True:
        choice = get_input("Which disk should ArchAI install to? (number or path):")
        if choice.isdigit() and 1 <= int(choice) <= len(disks):
            disk = disks[int(choice)-1]["name"]
        elif choice.startswith("/dev/"):
            disk = choice
        else:
            print("  Please enter a number or a path like /dev/sda\n")
            continue

        print(f"\n  \033[0;33m⚠  This will erase everything on {disk}. Type YES to confirm:\033[0m ", end="", flush=True)
        if input().strip() == "YES":
            return disk
        print("  Cancelled.\n")


# ── Installation with AI error handling ───────────────────────────────────────

async def run_install(profile: dict, disk: str, username: str, timezone: str,
                      attempt: int = 1) -> bool:
    """Run the install script. On failure, let the AI fix and retry automatically."""
    log(f"Starting {profile['key']} install on {disk} (attempt {attempt})")

    print(f"\n\033[0;37m  Installing \033[1;36m{profile['label']}\033[0;37m to "
          f"\033[1;36m{disk}\033[0;37m")
    if attempt > 1:
        print(f"\033[0;90m  (attempt {attempt})\033[0m")
    print(f"\033[0;90m  ─────────────────────────────────────────────────────\033[0m\n")

    proc = subprocess.Popen(
        ["bash", str(profile["script"]), disk, username, timezone],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        env=os.environ.copy()
    )

    output_lines = []
    for line in proc.stdout:
        line = line.rstrip()
        output_lines.append(line)
        if any(marker in line for marker in ["▶", "✓", "⚠", "█", "INFO", "ERROR"]):
            print(f"  {line}")
        log(line)

    proc.wait()

    if proc.returncode == 0:
        return True

    # ── Installation failed ───────────────────────────────────────────────────
    error_context = "\n".join(output_lines[-25:])
    print(f"\n\033[1;31m  ✗ Error on attempt {attempt}\033[0m")
    print(f"\033[0;31m{error_context}\033[0m\n")

    # Give up after 3 attempts to prevent infinite loops
    if attempt >= 3:
        print("\033[1;31m  ✗ Could not recover after 3 attempts.\033[0m\n")
        speak("Installation failed after three attempts.")
        print("  \033[0;36mGo back to the menu? (yes/no):\033[0m ", end="", flush=True)
        if input().strip().lower() != "no":
            return False
        return False

    if not ai_available():
        # No AI — ask the user directly
        speak("Installation failed.")
        print("  \033[0;36mRetry or go back to menu? (retry/menu):\033[0m ", end="", flush=True)
        return input().strip().lower() == "retry"

    # ── AI attempts to diagnose and fix ───────────────────────────────────────
    print(f"\033[1;36m  AI is analyzing and attempting to fix...\033[0m\n")
    speak("I hit an error. Let me try to fix it.")

    fix_prompt = (
        f"The ArchAI installer failed installing a '{profile['key']}' profile to {disk}.\n"
        f"This is attempt {attempt} of 3.\n\n"
        f"Error output:\n{error_context}\n\n"
        f"Instructions:\n"
        f"1. Use run_shell_command to investigate (lsblk, cat /proc/partitions, dmesg | tail, etc.)\n"
        f"2. Use run_shell_command to fix the issue — unmount stuck mounts, fix partition names, "
        f"   clean up /mnt, or whatever the error requires.\n"
        f"3. After fixing, reply with a ONE sentence summary of what you fixed.\n"
        f"4. Do NOT re-run the full install script — just fix the underlying issue so retry will work.\n"
        f"Be direct. Execute fixes immediately."
    )

    fix_response = await ask_ai(fix_prompt)

    if fix_response:
        ai_print(fix_response)
        speak(fix_response)

    # Clean up /mnt before retry in case it's in a partial state
    subprocess.run(["umount", "-R", "/mnt"], capture_output=True)

    print(f"\n\033[0;36m  Retrying installation...\033[0m\n")
    return await run_install(profile, disk, username, timezone, attempt=attempt + 1)


# ── Timezone helper ───────────────────────────────────────────────────────────

def guess_timezone() -> str:
    try:
        r = subprocess.run(["curl", "-s", "--max-time", "3", "https://ipapi.co/timezone"],
                           capture_output=True, text=True)
        if r.stdout.strip():
            return r.stdout.strip()
    except Exception:
        pass
    return "UTC"


# ── Main flow ─────────────────────────────────────────────────────────────────

async def main():
    clear()
    print(BANNER)

    gpu = detect_gpu()
    ram = detect_ram_gb()
    print(f"\033[0;90m  Detected: {gpu} GPU  │  {ram}GB RAM\033[0m\n")

    # AI greeting — only if daemon is reachable
    if Path(SOCKET_PATH).exists():
        print(f"\033[1;36m  AI:\033[0m ", end="", flush=True)
        greeting = await ask_ai(
            "You are ArchAI, an AI installer. "
            f"User hardware: {gpu} GPU, {ram}GB RAM. "
            "Say one sentence only: confirm hardware looks good and tell them to pick a profile below. "
            "Do NOT say 'Have a nice day' or any farewell. Do NOT ask questions. "
            "End with nothing — the profile menu appears next."
        )
        print(f"\033[0;37m{greeting}\033[0m\n")
        speak(greeting)
    else:
        print(f"\033[0;90m  AI layer loading — using text mode. Voice activates when ready.\033[0m\n")

    while True:
        profile = choose_profile()
        print(f"\n  \033[0;32m✓ Profile: {profile['label']}\033[0m\n")
        speak(f"Great. Setting up your {profile['label']}.")

        disk = choose_disk()

        print()
        username = get_input("Username:")
        while not username.isidentifier():
            print("  Lowercase letters and numbers only.\n")
            username = get_input("Username:")

        print(f"  \033[0;36m  Password for {username}:\033[0m ", end="", flush=True)
        import getpass
        password = getpass.getpass("")

        guessed_tz = guess_timezone()
        timezone   = get_input(f"Timezone (default: {guessed_tz}):") or guessed_tz

        print(f"""
  \033[1;37m  Ready to install:\033[0m
  \033[0;36m  Profile  \033[0m {profile['label']}
  \033[0;36m  Disk     \033[0m {disk}
  \033[0;36m  User     \033[0m {username}
  \033[0;36m  Timezone \033[0m {timezone}
  \033[0;33m
  This will erase {disk}. Type GO to start:\033[0m """, end="", flush=True)

        if input().strip() != "GO":
            print("  Cancelled — going back to menu.\n")
            continue

        speak(f"Installing your {profile['label']}. I'll tell you if anything goes wrong.")

        retry = await run_install(profile, disk, username, timezone)
        if retry:
            continue

        # Success
        done_msg = await ask_ai(
            f"The {profile['key']} profile installed successfully. "
            "Tell the user in one sentence: remove USB and reboot. "
            "Be brief — this will be spoken aloud."
        )
        print(f"\n  \033[1;32m✓ Installation complete.\033[0m")
        ai_print(done_msg)
        speak(done_msg)
        break


if __name__ == "__main__":
    asyncio.run(main())
