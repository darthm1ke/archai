#!/opt/archspeech/bin/python3
"""
ArchAI Daemon
Multi-backend: Anthropic (Claude), OpenAI, Ollama, LM Studio, custom endpoint,
or local TinyLlama 1.1B (always available, no internet required).
Configured via /etc/archspeech/config.json.
"""

import os
import json
import subprocess
import logging
import asyncio
from pathlib import Path

CONFIG_PATH = Path("/etc/archspeech/config.json")
LOG_PATH    = Path("/var/log/archspeech/daemon.log")
SOCKET_PATH = "/run/archspeech/daemon.sock"

logging.basicConfig(
    filename=str(LOG_PATH),
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s"
)
log = logging.getLogger("archspeech")


def load_config() -> dict:
    if not CONFIG_PATH.exists():
        raise FileNotFoundError(f"Config not found at {CONFIG_PATH}. Run archspeech-setup first.")
    with open(CONFIG_PATH) as f:
        return json.load(f)


def run_command(command: str) -> tuple[int, str, str]:
    log.info(f"Executing: {command}")
    result = subprocess.run(command, shell=True, capture_output=True, text=True, timeout=120)
    log.info(f"Exit {result.returncode}: {result.stdout[:200]}")
    return result.returncode, result.stdout, result.stderr


# ── Tool definitions (shared across all backends) ────────────────────────────

TOOLS_ANTHROPIC = [
    {
        "name": "run_shell_command",
        "description": "Execute a shell command. Use sudo where the scoped sudoers rules permit.",
        "input_schema": {
            "type": "object",
            "properties": {
                "command":     {"type": "string", "description": "Shell command to run."},
                "explanation": {"type": "string", "description": "Plain-English explanation of what this does."}
            },
            "required": ["command", "explanation"]
        }
    },
    {
        "name": "read_file",
        "description": "Read a system file.",
        "input_schema": {
            "type": "object",
            "properties": {"path": {"type": "string"}},
            "required": ["path"]
        }
    },
    {
        "name": "write_file",
        "description": "Write content to a system file.",
        "input_schema": {
            "type": "object",
            "properties": {
                "path":    {"type": "string"},
                "content": {"type": "string"}
            },
            "required": ["path", "content"]
        }
    }
]

TOOLS_OPENAI = [
    {
        "type": "function",
        "function": {
            "name": "run_shell_command",
            "description": "Execute a shell command. Use sudo where the scoped sudoers rules permit.",
            "parameters": {
                "type": "object",
                "properties": {
                    "command":     {"type": "string", "description": "Shell command to run."},
                    "explanation": {"type": "string", "description": "Plain-English explanation."}
                },
                "required": ["command", "explanation"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "read_file",
            "description": "Read a system file.",
            "parameters": {
                "type": "object",
                "properties": {"path": {"type": "string"}},
                "required": ["path"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "write_file",
            "description": "Write content to a system file.",
            "parameters": {
                "type": "object",
                "properties": {
                    "path":    {"type": "string"},
                    "content": {"type": "string"}
                },
                "required": ["path", "content"]
            }
        }
    }
]

SYSTEM_PROMPT = """You are ArchSpeech, the AI core of an Arch Linux-based operating system.
You have direct, scoped access to system tools and can manage packages, services, files,
web servers, SSL certificates, network configuration, and more on behalf of the user.

Guidelines:
- Always explain what you are about to do before executing commands.
- Prefer safe, reversible operations. Warn before anything destructive.
- When installing packages, use pacman first; yay only for AUR packages.
- Keep responses concise — they may be spoken aloud via TTS.
- Execute multi-step tasks in order and report progress.
- You run as the 'archspeech' system user with scoped sudo."""


# ── Tool execution (shared) ───────────────────────────────────────────────────

def execute_tool(name: str, args: dict) -> str:
    if name == "run_shell_command":
        log.info(args.get("explanation", ""))
        rc, stdout, stderr = run_command(args["command"])
        return stdout if rc == 0 else f"ERROR (exit {rc}): {stderr}"
    elif name == "read_file":
        try:
            return Path(args["path"]).read_text()
        except Exception as e:
            return f"Error reading file: {e}"
    elif name == "write_file":
        try:
            p = Path(args["path"])
            p.parent.mkdir(parents=True, exist_ok=True)
            p.write_text(args["content"])
            return f"Written: {args['path']}"
        except Exception as e:
            return f"Error writing file: {e}"
    return f"Unknown tool: {name}"


# ── Anthropic backend ─────────────────────────────────────────────────────────

async def handle_anthropic(user_message: str, config: dict) -> str:
    import anthropic
    client = anthropic.Anthropic(api_key=config["api_key"])
    messages = [{"role": "user", "content": user_message}]

    while True:
        response = client.messages.create(
            model=config.get("model", "claude-opus-4-7"),
            max_tokens=4096,
            system=SYSTEM_PROMPT,
            tools=TOOLS_ANTHROPIC,
            messages=messages
        )

        text_parts = [b.text for b in response.content if hasattr(b, "text")]

        if response.stop_reason == "end_turn":
            return " ".join(text_parts)

        if response.stop_reason == "tool_use":
            messages.append({"role": "assistant", "content": response.content})
            tool_results = []
            for block in response.content:
                if block.type != "tool_use":
                    continue
                result = execute_tool(block.name, block.input)
                tool_results.append({
                    "type": "tool_result",
                    "tool_use_id": block.id,
                    "content": result
                })
            messages.append({"role": "user", "content": tool_results})


# ── OpenAI-compatible backend (OpenAI, Ollama, LM Studio, custom) ─────────────

async def handle_openai_compatible(user_message: str, config: dict) -> str:
    from openai import OpenAI
    client = OpenAI(
        api_key=config.get("api_key", "ollama"),
        base_url=config.get("api_url", "https://api.openai.com/v1")
    )
    messages = [
        {"role": "system", "content": SYSTEM_PROMPT},
        {"role": "user",   "content": user_message}
    ]

    # Some local models don't support tool calling — try with tools, fall back without
    use_tools = config.get("tools_enabled", True)

    while True:
        kwargs = dict(
            model=config.get("model", "gpt-4o"),
            messages=messages,
            max_tokens=4096
        )
        if use_tools:
            kwargs["tools"] = TOOLS_OPENAI
            kwargs["tool_choice"] = "auto"
        # Pass extra_body if specified (e.g. think:false for Qwen3)
        if config.get("extra_body"):
            kwargs["extra_body"] = config["extra_body"]

        try:
            response = client.chat.completions.create(**kwargs)
        except Exception as e:
            if "tool" in str(e).lower() and use_tools:
                log.warning("Model doesn't support tools, retrying without.")
                use_tools = False
                continue
            raise

        choice = response.choices[0]
        msg = choice.message

        if not msg.tool_calls:
            return msg.content or ""

        messages.append(msg)
        for call in msg.tool_calls:
            args = json.loads(call.function.arguments)
            result = execute_tool(call.function.name, args)
            messages.append({
                "role":         "tool",
                "tool_call_id": call.id,
                "content":      result
            })


# ── Local TinyLlama backend ───────────────────────────────────────────────────

CHEATSHEET_DIR = Path("/etc/archspeech/cheatsheets")
CHEATSHEET_MAP = {
    "pentest": ["pentest.md", "networking.md"],
    "hack":    ["pentest.md", "networking.md"],
    "nmap":    ["pentest.md"],
    "scan":    ["pentest.md"],
    "install": ["install.md"],
    "disk":    ["install.md"],
    "parted":  ["install.md"],
    "pacman":  ["packages.md"],
    "package": ["packages.md"],
    "yay":     ["packages.md"],
    "service": ["services.md"],
    "systemctl": ["services.md"],
    "nginx":   ["webserver.md"],
    "apache":  ["webserver.md"],
    "ssl":     ["webserver.md"],
    "certbot": ["webserver.md"],
    "wifi":    ["networking.md"],
    "network": ["networking.md"],
    "vpn":     ["networking.md"],
}


def load_cheatsheet(message: str) -> str:
    """Return relevant cheat sheet content based on keywords in the message."""
    ml = message.lower()
    sheets_to_load = set()
    for keyword, files in CHEATSHEET_MAP.items():
        if keyword in ml:
            sheets_to_load.update(files)
    if not sheets_to_load:
        return ""
    context = "\n\n=== REFERENCE ===\n"
    for fname in sheets_to_load:
        path = CHEATSHEET_DIR / fname
        if path.exists():
            context += path.read_text() + "\n"
    return context


def ensure_ollama_model(model: str = "qwen3:0.6b") -> bool:
    """Pull the model if Ollama is running but doesn't have it yet."""
    try:
        result = subprocess.run(["ollama", "list"], capture_output=True, text=True, timeout=5)
        if model in result.stdout:
            return True
        log.info(f"Pulling {model} via Ollama (first boot download)...")
        subprocess.run(["ollama", "pull", model], timeout=300)
        log.info(f"{model} ready.")
        return True
    except Exception as e:
        log.error(f"Ollama model setup failed: {e}")
        return False


async def handle_local(user_message: str) -> str:
    """Use Ollama native /api/chat — supports think:false at top level unlike OpenAI-compat endpoint."""
    ensure_ollama_model("aios-local")
    context = load_cheatsheet(user_message)
    import urllib.request as _ur, json as _json

    payload = _json.dumps({
        "model":   "aios-local",
        "messages": [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user",   "content": user_message + context}
        ],
        "think":  False,   # Disable Qwen3 thinking — must be top-level in native API
        "stream": False
    }).encode()

    req = _ur.Request(
        "http://localhost:11434/api/chat",
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST"
    )
    try:
        with _ur.urlopen(req, timeout=300) as resp:
            result = _json.loads(resp.read())
            return result.get("message", {}).get("content", "").strip()
    except Exception as e:
        log.error(f"Ollama native API error: {e}")
        return "Local AI is starting up. Try again in a moment."


# ── Router ────────────────────────────────────────────────────────────────────

async def handle_request(user_message: str, config: dict) -> str:
    provider = config.get("provider", "local").lower()

    # Always try cloud first if configured, fall back to local on any failure
    if provider == "anthropic":
        try:
            return await handle_anthropic(user_message, config)
        except Exception as e:
            log.warning(f"Anthropic failed ({e}), falling back to TinyLlama")
            return await handle_local(user_message)

    elif provider in ("openai", "openai_compatible"):
        try:
            return await handle_openai_compatible(user_message, config)
        except Exception as e:
            log.warning(f"OpenAI-compatible failed ({e}), falling back to TinyLlama")
            return await handle_local(user_message)

    else:
        return await handle_local(user_message)


# ── Unix socket server ────────────────────────────────────────────────────────

async def unix_socket_server():
    config = load_config()
    socket_path = Path(SOCKET_PATH)
    socket_path.parent.mkdir(parents=True, exist_ok=True)
    if socket_path.exists():
        socket_path.unlink()

    log.info(f"ArchSpeech daemon started (provider: {config.get('provider','anthropic')}).")

    async def handle_client(reader, writer):
        try:
            data = await reader.read(65536)
            message = data.decode().strip()
            log.info(f"Received: {message[:100]}")
            reply = await handle_request(message, config)
            writer.write(reply.encode())
            await writer.drain()
        except Exception as e:
            log.error(f"Handler error: {e}")
            writer.write(f"Error: {e}".encode())
            await writer.drain()
        finally:
            writer.close()

    server = await asyncio.start_unix_server(handle_client, path=str(socket_path))
    async with server:
        await server.serve_forever()


if __name__ == "__main__":
    asyncio.run(unix_socket_server())
