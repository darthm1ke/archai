#!/usr/bin/env bash
# AIos status pane — reads real progress from model setup script

LOG="/var/log/archspeech/execution.log"
STATUS_FILE="/var/lib/aios/model_status"
READY_FLAG="/var/lib/aios/.model_ready"

touch "$LOG" 2>/dev/null

printf '\033[0;90m  ── AIos Status ─────────────────────────────────────────────\033[0m\n'

# Show live model import progress by tailing the status file
if [ ! -f "$READY_FLAG" ]; then
    printf '\033[0;33m  Model import starting...\033[0m\n'
    last_status=""
    while [ ! -f "$READY_FLAG" ]; do
        if [ -f "$STATUS_FILE" ]; then
            current="$(cat "$STATUS_FILE" 2>/dev/null)"
            if [ "$current" != "$last_status" ]; then
                # Color based on content
                if echo "$current" | grep -q "ERROR\|FAILED"; then
                    printf '\r\033[0;31m  %s\033[0m\n' "$current"
                elif echo "$current" | grep -q "READY"; then
                    printf '\r\033[0;32m  ✓ %s\033[0m\n' "$current"
                    break
                else
                    printf '\r\033[0;33m  %s\033[0m\033[K' "$current"
                fi
                last_status="$current"
            fi
        fi
        sleep 1
    done

    if [ -f "$READY_FLAG" ]; then
        printf '\n\033[0;32m  ✓ AI model fully loaded — ready\033[0m\n\n'
    fi
fi

# Live execution log
printf '\033[0;90m  ── Live activity ────────────────────────────────────────────\033[0m\n'
tail -f "$LOG" 2>/dev/null || sleep infinity
