#!/usr/bin/env bash
# AIos POC status pane вЂ” shows EVERYTHING from every relevant service live

printf '\033[0;90mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m\n'
printf '\033[1;36m  AIos Live System Log\033[0m\n'
printf '\033[0;90m  Showing: kernel В· ollama В· model-init В· ai-daemon В· ptt\033[0m\n'
printf '\033[0;90mв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ\033[0m\n'

# Wait briefly for journal to be available
sleep 2

# Stream everything from all AIos-related services + kernel in real time
# -f = follow, -n 30 = show last 30 lines first, -p = priority
exec journalctl -f \
    -n 30 \
    -u ollama.service \
    -u ollama-vulkan.service \
    -u aios-model-init.service \
    -u archspeech.service \
    -u archspeech-ptt.service \
    -u archspeech-voice.service \
    -u NetworkManager.service \
    --no-hostname \
    --output=short-monotonic \
    2>/dev/null || \
journalctl -f -n 30 --no-hostname --output=short-monotonic
