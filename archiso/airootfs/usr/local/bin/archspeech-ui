#!/usr/bin/env bash
# AIos UI — tmux with AI terminal (top) and status pane (bottom)

SESSION="aios"

tmux kill-session -t "$SESSION" 2>/dev/null
tmux new-session -d -s "$SESSION" -x "$(tput cols)" -y "$(tput lines)"
tmux set-option -t "$SESSION" allow-rename off
tmux set-option -t "$SESSION" status on
tmux set-option -t "$SESSION" status-style         "bg=colour235,fg=colour39"
tmux set-option -t "$SESSION" status-left          " #[bold,fg=colour39]AI#[fg=colour255]os#[nobold]  "
tmux set-option -t "$SESSION" status-right         " #[fg=colour245]Hold [Caps Lock] to speak  |  Right Ctrl in VM "
tmux set-option -t "$SESSION" pane-border-style    "fg=colour238"
tmux set-option -t "$SESSION" pane-active-border-style "fg=colour39"

# Split 75/25
tmux split-window -t "$SESSION" -v -p 25

# Bottom pane — proper script file, no inline code
tmux send-keys -t "$SESSION:0.1" "/usr/local/bin/aios-status" Enter

# Top pane — AI terminal
tmux select-pane -t "$SESSION:0.0"
tmux send-keys -t "$SESSION:0.0" "/usr/local/bin/archspeech-live" Enter

tmux attach-session -t "$SESSION"
