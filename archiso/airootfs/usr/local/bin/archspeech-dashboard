#!/opt/archspeech/bin/python3
"""
AIos Dashboard — ANSI-based, works on VGA console, X11, Wayland, SSH.
No curses dependency — pure escape codes for maximum compatibility.
"""

import asyncio, subprocess, threading, time, os, sys, select
import json, urllib.request, struct, math
from pathlib import Path

SOCKET_PATH = "/run/archspeech/daemon.sock"
STATUS_FILE = Path("/var/lib/aios/model_status")
READY_FLAG  = Path("/var/lib/aios/.model_ready")
VOICE_FIFO  = Path("/run/archspeech/voice_input")

# ANSI helpers
def cls():       print("\033[2J\033[H", end="", flush=True)
def goto(r, c):  print(f"\033[{r};{c}H", end="", flush=True)
def bold(s):     return f"\033[1m{s}\033[0m"
def cyan(s):     return f"\033[1;36m{s}\033[0m"
def green(s):    return f"\033[0;32m{s}\033[0m"
def yellow(s):   return f"\033[0;33m{s}\033[0m"
def red(s):      return f"\033[0;31m{s}\033[0m"
def dim(s):      return f"\033[0;90m{s}\033[0m"

def bar(pct, w, fill="█", empty="░"):
    f = int(w * pct / 100)
    return fill * f + empty * (w - f)

def mic_bar(level, w):
    f = int(w * level)
    return "▄" * f + " " * (w - f)

def box(title, content_lines, width):
    top    = f"┌ {title} {'─' * max(0, width - len(title) - 4)}┐"
    bottom = "└" + "─" * (width - 2) + "┘"
    lines  = [top]
    for line in content_lines:
        padded = line[:width-4]
        lines.append(f"│ {padded:<{width-4}} │")
    lines.append(bottom)
    return lines

# ── Shared state ──────────────────────────────────────────────────────────────
S = {
    "mic":        0.0,
    "vol":        80,
    "gpu":        0,
    "bat":        -1,
    "bat_chg":    False,
    "cpu":        0,
    "ram_used":   0,
    "ram_total":  0,
    "net_up":     0,
    "net_down":   0,
    "ai_status":  "Starting...",
    "ai_ready":   False,
    "messages":   [],
    "voice_q":    [],
    "recording":  False,
}
SL = threading.Lock()

# ── Hardware ──────────────────────────────────────────────────────────────────
def hw_thread():
    while True:
        try:
            # Battery
            for b in ["BAT0","BAT1"]:
                p = Path(f"/sys/class/power_supply/{b}/capacity")
                if p.exists():
                    pct = int(p.read_text())
                    chg = Path(f"/sys/class/power_supply/{b}/status").read_text().strip() == "Charging"
                    with SL: S["bat"] = pct; S["bat_chg"] = chg
                    break
            # GPU (Intel)
            for g in Path("/sys/class/drm").glob("card*/gt_cur_freq_mhz"):
                mx = g.parent / "gt_max_freq_mhz"
                if mx.exists():
                    pct = int(int(g.read_text()) / int(mx.read_text()) * 100)
                    with SL: S["gpu"] = pct
                    break
            # CPU
            with open("/proc/stat") as f:
                vals = list(map(int, f.readline().split()[1:]))
            idle, total = vals[3], sum(vals)
            if not hasattr(hw_thread, "prev"):
                hw_thread.prev = (idle, total)
            pi, pt = hw_thread.prev; hw_thread.prev = (idle, total)
            di, dt = idle-pi, total-pt
            with SL: S["cpu"] = int((1 - di/dt)*100) if dt else 0
            # RAM
            info = {}
            with open("/proc/meminfo") as f:
                for line in f:
                    k, v = line.split(":")
                    info[k.strip()] = int(v.split()[0])
            rt = info.get("MemTotal",0)//1024
            ru = rt - info.get("MemAvailable",0)//1024
            with SL: S["ram_used"] = ru; S["ram_total"] = rt
            # Volume
            try:
                r = subprocess.run(["amixer","get","Master"], capture_output=True, text=True, timeout=1)
                for line in r.stdout.split("\n"):
                    if "%" in line:
                        vol = int(line.split("[")[1].split("%")[0])
                        with SL: S["vol"] = vol
                        break
            except Exception: pass
            # AI status
            st = STATUS_FILE.read_text().strip() if STATUS_FILE.exists() else ""
            rdy = READY_FLAG.exists()
            with SL: S["ai_status"] = st; S["ai_ready"] = rdy
        except Exception: pass
        time.sleep(1)

def mic_thread():
    """Continuously read mic level — suppress ALL stderr to avoid ALSA spam."""
    try:
        import pyaudio, os as _os
        # Redirect stderr to suppress ALSA/Jack errors
        devnull = _os.open("/dev/null", _os.O_WRONLY)
        old_err = _os.dup(2)
        _os.dup2(devnull, 2)
        try:
            pa = pyaudio.PyAudio()
            stream = pa.open(format=pyaudio.paInt16, channels=1, rate=16000,
                             input=True, frames_per_buffer=512)
            _os.dup2(old_err, 2)  # restore stderr
            while True:
                try:
                    data = stream.read(512, exception_on_overflow=False)
                    samples = struct.unpack(f"{len(data)//2}h", data)
                    rms = math.sqrt(sum(s*s for s in samples) / len(samples))
                    with SL: S["mic"] = min(1.0, rms / 6000)
                except Exception: time.sleep(0.05)
        except Exception:
            _os.dup2(old_err, 2)
    except Exception: pass

def voice_thread():
    try:
        if not VOICE_FIFO.exists():
            os.mkfifo(str(VOICE_FIFO))
        while True:
            with open(VOICE_FIFO) as f:
                line = f.read().strip()
                if line:
                    with SL: S["voice_q"].append(line)
    except Exception: pass

# ── AI ────────────────────────────────────────────────────────────────────────
def ai_available():
    try:
        urllib.request.urlopen("http://localhost:11434/api/version", timeout=1)
        return True
    except Exception: return False

async def ask_ai(msg):
    payload = json.dumps({
        "model": "qwen2.5:0.5b",
        "messages": [
            {"role":"system","content":"You are AIos, an AI assistant for Arch Linux. Give short direct commands. Use pacman for packages, systemctl for services. Be concise."},
            {"role":"user","content": msg}
        ],
        "stream": False,
        "options": {"num_ctx":2048,"temperature":0.7,"num_predict":256}
    }).encode()
    req = urllib.request.Request("http://localhost:11434/api/chat",
        data=payload, headers={"Content-Type":"application/json"}, method="POST")
    with urllib.request.urlopen(req, timeout=120) as resp:
        return json.loads(resp.read()).get("message",{}).get("content","").strip()

def fmt_bytes(b):
    if b < 1024: return f"{b}B/s"
    if b < 1048576: return f"{b//1024}K/s"
    return f"{b//1048576}M/s"

# ── Render ────────────────────────────────────────────────────────────────────
def render(messages, input_buf):
    try:
        cols = int(subprocess.run(["tput","cols"], capture_output=True, text=True).stdout.strip())
        rows = int(subprocess.run(["tput","lines"], capture_output=True, text=True).stdout.strip())
    except Exception: cols, rows = 80, 24

    with SL:
        mic   = S["mic"]; vol = S["vol"]; gpu = S["gpu"]
        bat   = S["bat"]; bat_chg = S["bat_chg"]; cpu = S["cpu"]
        ru    = S["ram_used"]; rt = S["ram_total"]
        nu    = S["net_up"]; nd = S["net_down"]
        ai_st = S["ai_status"]; ai_rdy = S["ai_ready"]
        rec   = S["recording"]

    out = []

    # ── Row 1: mic | speaker | gpu | battery ─────────────────────────────────
    half = cols // 2; q = cols // 4; eq = cols - q*3
    mic_title = "microphone 🔴" if rec else "microphone"
    bw = q - 8
    mic_lines  = [f"{mic_bar(mic, bw)} {int(mic*100):3d}%"]
    spk_lines  = [f"{bar(vol, bw)} {vol:3d}%"]
    gpu_lines  = [f"{bar(gpu, 4)} {gpu:3d}%"]
    bat_label  = f"{bat}% ⚡" if bat_chg else f"{bat}%" if bat >= 0 else "N/A"
    bat_color  = green if bat > 50 else yellow if bat > 20 else red
    bat_lines  = [bat_color(bat_label)]

    row1_boxes = [
        box(mic_title, mic_lines, q),
        box("speaker", spk_lines, q),
        box("gpu", gpu_lines, q),
        box("battery", bat_lines, eq),
    ]
    for i in range(3):
        line = ""
        for b_lines in row1_boxes:
            line += b_lines[i] if i < len(b_lines) else ""
        out.append(line[:cols])

    # ── Row 2: ai status | system ─────────────────────────────────────────────
    if ai_rdy:
        ai_lines = [green("qwen2.5:0.5b  ready ✓"), dim("Hold Caps Lock to speak")]
    else:
        pct = 0
        if "%" in ai_st:
            try: pct = int(ai_st.split("%")[0].split()[-1])
            except Exception: pass
        bw2 = half - 8
        ai_lines = [ai_st[:half-4], f"{bar(pct, bw2)} {pct}%"]

    sw = cols - half
    sys_lines = [
        f"CPU {cpu:3d}%  {bar(cpu, sw-12)}",
        f"RAM {ru}MB / {rt}MB",
        f"NET ↑{fmt_bytes(nu)}  ↓{fmt_bytes(nd)}",
    ]
    ai_box  = box("ai model", ai_lines, half)
    sys_box = box("system",   sys_lines, sw)
    for i in range(4):
        al = ai_box[i]  if i < len(ai_box)  else " " * half
        sl = sys_box[i] if i < len(sys_box) else ""
        out.append((al + sl)[:cols])

    # ── Conversation ──────────────────────────────────────────────────────────
    conv_h = rows - len(out) - 4
    out.append("┌" + f" conversation ".center(cols-2, "─") + "┐")
    visible = messages[-(conv_h):]
    for role, text in visible:
        line = f"  {role}: {text}"
        if role == "AI":
            out.append("│" + cyan(line[:cols-4]).ljust(cols-2) + "│")
        else:
            out.append("│" + green(line[:cols-4]).ljust(cols-2) + "│")
    for _ in range(conv_h - len(visible)):
        out.append("│" + " "*(cols-2) + "│")
    out.append("└" + "─"*(cols-2) + "┘")

    # ── Input bar ─────────────────────────────────────────────────────────────
    prompt = "  You: " + input_buf
    hint   = dim("  [Caps Lock] speak  │  [Right Ctrl] VM  │  [Enter] send  │  [Esc] quit")
    out.append(prompt[:cols])
    out.append(hint[:cols])

    cls()
    print("\n".join(out), flush=True)

# ── Main ──────────────────────────────────────────────────────────────────────
async def main():
    threading.Thread(target=hw_thread,    daemon=True).start()
    threading.Thread(target=mic_thread,   daemon=True).start()
    threading.Thread(target=voice_thread, daemon=True).start()

    messages = [("AI", "Starting up — model loading below...")]
    if ai_available():
        messages = [("AI", "I'm ready. What would you like to do?")]

    input_buf = ""
    os.system("tput civis 2>/dev/null")  # hide cursor during render

    try:
        while True:
            with SL:
                vq = S["voice_q"][:]
                S["voice_q"].clear()
            for vt in vq:
                input_buf = vt

            render(messages, input_buf)

            # Non-blocking keyboard
            import termios, tty
            fd = sys.stdin.fileno()
            old = termios.tcgetattr(fd)
            try:
                tty.setraw(fd)
                rlist, _, _ = select.select([sys.stdin], [], [], 0.15)
                if rlist:
                    ch = sys.stdin.read(1)
                    if ch == "\x1b":  # Esc
                        break
                    elif ch in ("\r", "\n"):
                        if input_buf.strip():
                            msg = input_buf.strip()
                            input_buf = ""
                            messages.append(("You", msg))
                            messages.append(("AI", "thinking..."))
                            render(messages, input_buf)
                            try:
                                resp = await ask_ai(msg)
                                messages[-1] = ("AI", resp)
                            except Exception as e:
                                messages[-1] = ("AI", f"Error: {e}")
                    elif ch == "\x7f":
                        input_buf = input_buf[:-1]
                    elif ch.isprintable():
                        input_buf += ch
            finally:
                termios.tcsetattr(fd, termios.TCSADRAIN, old)

            await asyncio.sleep(0.05)
    finally:
        os.system("tput cnorm 2>/dev/null")  # restore cursor

if __name__ == "__main__":
    asyncio.run(main())
