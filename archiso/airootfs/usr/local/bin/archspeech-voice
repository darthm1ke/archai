#!/opt/archspeech/bin/python3
"""
ArchSpeech Voice Module
Listens for a wake word, captures speech, sends to the AI daemon,
and speaks the response back using TTS.

Dependencies: whisper-cpp (STT), piper (TTS), pyaudio
"""

import asyncio
import subprocess
import tempfile
import os
import sys
from pathlib import Path

SOCKET_PATH = "/run/archspeech/daemon.sock"
WAKE_WORD = "archspeech"
WHISPER_BIN = "/usr/local/bin/whisper-cli"
PIPER_BIN = "/usr/local/bin/piper"
PIPER_MODEL = "/usr/local/lib/archspeech/piper-voice.onnx"


def record_audio(duration: int = 5) -> str:
    """Record audio from mic, return path to WAV file."""
    tmp = tempfile.mktemp(suffix=".wav")
    subprocess.run(
        ["arecord", "-f", "S16_LE", "-r", "16000", "-c", "1", "-d", str(duration), tmp],
        check=True, capture_output=True
    )
    return tmp


def transcribe(wav_path: str) -> str:
    """Run whisper-cpp on a WAV file, return transcript."""
    result = subprocess.run(
        [WHISPER_BIN, "-m", "/usr/local/lib/archspeech/whisper-model.bin",
         "-f", wav_path, "--no-timestamps", "-otxt"],
        capture_output=True, text=True
    )
    txt_path = wav_path.replace(".wav", ".wav.txt")
    if Path(txt_path).exists():
        text = Path(txt_path).read_text().strip()
        Path(txt_path).unlink()
        return text
    return result.stdout.strip()


def speak(text: str):
    """Convert text to speech using piper and play it."""
    with tempfile.NamedTemporaryFile(suffix=".wav", delete=False) as f:
        wav_path = f.name
    subprocess.run(
        [PIPER_BIN, "--model", PIPER_MODEL, "--output_file", wav_path],
        input=text.encode(), check=True, capture_output=True
    )
    subprocess.run(["aplay", wav_path], capture_output=True)
    os.unlink(wav_path)


async def send_to_daemon(message: str) -> str:
    reader, writer = await asyncio.open_unix_connection(SOCKET_PATH)
    writer.write(message.encode())
    writer.write_eof()
    await writer.drain()
    response = await reader.read(65536)
    writer.close()
    return response.decode()


async def voice_loop():
    print("ArchSpeech voice module active. Listening for wake word...")
    speak("ArchSpeech is ready. Say ArchSpeech to give a command.")

    while True:
        try:
            # Listen for wake word in short bursts
            wav = record_audio(duration=3)
            transcript = transcribe(wav).lower()
            Path(wav).unlink(missing_ok=True)

            if WAKE_WORD not in transcript:
                continue

            speak("Listening.")
            command_wav = record_audio(duration=7)
            command = transcribe(command_wav)
            Path(command_wav).unlink(missing_ok=True)

            if not command.strip():
                speak("I didn't catch that. Try again.")
                continue

            print(f"Command: {command}")
            speak("On it.")

            response = await send_to_daemon(command)
            print(f"Response: {response}")
            speak(response)

        except KeyboardInterrupt:
            speak("ArchSpeech signing off.")
            break
        except Exception as e:
            print(f"Error: {e}", file=sys.stderr)


if __name__ == "__main__":
    asyncio.run(voice_loop())
